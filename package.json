{
  "name": "gates",
  "version": "0.1.0",
  "description": "AI Agent Harness — CLI and Terminal UI",
  "type": "module",
  "bin": {
    "gates": "./dist/index.js"
  },
  "scripts": {
    "build": "bun run tsc",
    "typecheck": "bun run tsc --noEmit",
    "dev": "bun --bun run src/index.ts",
    "postinstall": "bun run -e \"const{mkdirSync,cpSync,existsSync}=require('fs'),{join}=require('path'),h=require('os').homedir();const src=join(__dirname,'connectors');const dst=join(h,'.gates','connectors');if(existsSync(src)){mkdirSync(dst,{recursive:true});cpSync(src,dst,{recursive:true});}\""
  },
  "dependencies": {
    "@gatesai/core": "^0.1.0",
    "@gatesai/providers": "^0.1.2",
    "@gatesai/runtime": "^0.1.0",
    "@gatesai/sandbox": "^0.1.0",
    "@gatesai/skills": "^0.1.0",
    "@hono/node-server": "^1.12.0",
    "@opentui/core": "^0.2.6",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "effect": "4.0.0-beta.64",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.13",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
